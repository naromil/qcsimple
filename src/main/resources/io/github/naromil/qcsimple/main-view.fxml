<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane prefHeight="640.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.naromil.qcsimple.MainController">
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem accelerator="Shortcut+O" onAction="#onOpenMenuAction" text="Open Structure..." />
              <MenuItem accelerator="Shortcut+S" onAction="#onSaveMenuAction" text="Save" />
              <MenuItem onAction="#onSaveAsMenuAction" text="Save As..." />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Edit" />
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#showAboutDialog" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <bottom>
      <ToolBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <items>
            <TextField fx:id="blcFramework" prefHeight="26.0" prefWidth="120.0" promptText="Framework Block" />
            <TextField fx:id="blcColumn" prefHeight="26.0" prefWidth="120.0" promptText="Column Block" />
            <TextField fx:id="blcRow" prefHeight="26.0" prefWidth="120.0" promptText="Row Block" />
         </items>
      </ToolBar>
   </bottom>
</BorderPane>
