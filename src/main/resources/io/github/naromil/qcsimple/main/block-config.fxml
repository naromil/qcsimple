<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane alignment="CENTER" hgap="10.0" vgap="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.naromil.qcsimple.data.BlockConfigController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Block ID Configuration" GridPane.columnIndex="0" GridPane.columnSpan="4" GridPane.rowIndex="0" />

    <Label text="Framework Block ID:" GridPane.rowIndex="1" />
    <TextField fx:id="blocFramework" promptText="minecraft:stone" GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <Label text="Column Block ID:" GridPane.rowIndex="2" />
    <TextField fx:id="blocColumn" promptText="minecraft:oak_log" GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <Label text="Row Block ID:" GridPane.rowIndex="3" />
    <TextField fx:id="blocRow" promptText="minecraft:cobblestone" GridPane.columnIndex="1" GridPane.rowIndex="3" />

    <Label text="Floor Block ID:" GridPane.rowIndex="4" />
    <TextField fx:id="blocFloor" promptText="minecraft:oak_planks" GridPane.columnIndex="1" GridPane.rowIndex="4" />

    <Label text="Wall Block ID:" GridPane.rowIndex="5" />
    <TextField fx:id="blocWall" promptText="minecraft:oak_planks" GridPane.columnIndex="1" GridPane.rowIndex="5" />

    <Label text="Inner Wall .nbt:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
    <HBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="1">
        <TextField fx:id="pathInnerWall" editable="false" promptText="No file selected..." HBox.hgrow="ALWAYS" />
        <Button text="..." onAction="#onBrowseInnerWall" />
    </HBox>

    <Label text="Outer Wall .nbt:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
    <HBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="2">
        <TextField fx:id="pathOuterWall" editable="false" promptText="No file selected..." HBox.hgrow="ALWAYS" />
        <Button text="..." onAction="#onBrowseOuterWall" />
    </HBox>

    <Label text="Inner Column .nbt:" GridPane.columnIndex="2" GridPane.rowIndex="3" />
    <HBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="3">
        <TextField fx:id="pathInnerColumn" editable="false" promptText="No file selected..." HBox.hgrow="ALWAYS" />
        <Button text="..." onAction="#onBrowseInnerColumn" />
    </HBox>

    <Label text="Roof .nbt:" GridPane.columnIndex="2" GridPane.rowIndex="4" />
    <HBox spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="4">
        <TextField fx:id="pathRoof" editable="false" promptText="No file selected..." HBox.hgrow="ALWAYS" />
        <Button text="..." onAction="#onBrowseRoof" />
    </HBox>

    <HBox alignment="bottom_right" spacing="10" GridPane.columnIndex="3" GridPane.rowIndex="6">
        <Button onAction="#onCancelAction" text="Cancel" />
        <Button onAction="#onSaveAction" style="-fx-base: #28a745;" text="Save" />
    </HBox>

    <columnConstraints>
        <ColumnConstraints prefWidth="150.0" />
        <ColumnConstraints prefWidth="150.0" />
        <ColumnConstraints prefWidth="150.0" />
        <ColumnConstraints prefWidth="200.0" /> </columnConstraints>
</GridPane>